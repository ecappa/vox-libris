# === Serveur uniquement (ne jamais préfixer par VITE_) ===
# Clé RAGFlow : reste sur le backend (proxy Vite / fonctions Vercel).
RAGFLOW_ADMIN_API_KEY=

# Secret HMAC pour les cookies de session du proxy (recommandé en prod).
# Si absent, la clé admin RAGFlow sert de secours (moins idéal).
VOX_GATEWAY_SECRET=

# JSON optionnel : liste des assistants affichés dans l’UI
# [{"id":"uuid","label":"Mode jeune","description":"..."}]
RAGFLOW_PUBLIC_ASSISTANTS=
