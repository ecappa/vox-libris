# =============================================================================
# Vox Libris — variables d’environnement (exemple)
# =============================================================================
#
# Copier ce fichier vers .env.local et remplir les valeurs.
# .env.local est ignoré par git (ne jamais committer de secrets).
#
# IMPORTANT — sécurité front / back
# - Ne JAMAIS préfixer une clé secrète par VITE_ : tout ce qui commence par
#   VITE_ est injecté dans le bundle JavaScript visible dans le navigateur.
# - Les variables ci-dessous sont lues UNIQUEMENT par le serveur :
#   · en local : middleware Vite (src/server/vox-backend-gateway.ts)
#   · en prod  : fonctions serverless Vercel (dossier api/)
#
# Flux côté navigateur :
# 1) GET /api/session        → pose un cookie HttpOnly (session signée)
# 2) GET /api/vox/config     → liste publique des assistants (sans secret)
# 3) appels /api/ragflow/... → proxy vers RAGFlow (clé admin jamais exposée)
#
# Voir aussi : docs/instruction-ragflow.md, CLAUDE.md
# =============================================================================

# -----------------------------------------------------------------------------
# Obligatoire pour que l’app puisse parler à RAGFlow (proxy + indexation)
# -----------------------------------------------------------------------------
# Clé API « admin » RAGFlow (en-tête Authorization: Bearer …).
# Où la trouver : interface RAGFlow → paramètres / clé API (selon version).
# Sans cette variable : erreur 500 au chargement des datasets et du chat.
#
RAGFLOW_ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Recommandé (séparation des rôles)
# -----------------------------------------------------------------------------
# Secret utilisé UNIQUEMENT pour signer le cookie de session du proxy (HMAC).
# Génération rapide :  openssl rand -hex 32
#
# Si vide : le code retombe sur RAGFLOW_ADMIN_API_KEY pour signer le cookie
# (fonctionne en dev, moins propre en production).
#
VOX_GATEWAY_SECRET=

# -----------------------------------------------------------------------------
# Optionnel — personnaliser l’UI sans toucher au code
# -----------------------------------------------------------------------------
# JSON sur une seule ligne : assistants proposés dans la sidebar et le sélecteur
# du chat. Chaque entrée : id = UUID du chat RAGFlow, label, description.
#
# Si vide ou absent : valeurs par défaut dans api/lib/ragflow-gateway.ts
# (mode jeune + mode érudit Victor Hugo).
#
# Exemple (à adapter avec vos UUID réels) :
# RAGFLOW_PUBLIC_ASSISTANTS=[{"id":"xxxxxxxx","label":"Mode jeune","description":"Ton accessible"},{"id":"yyyyyyyy","label":"Mode érudit","description":"Analyse du corpus"}]
#
RAGFLOW_PUBLIC_ASSISTANTS=

# -----------------------------------------------------------------------------
# Retrieval + completions — rerank (optionnel mais recommandé)
# -----------------------------------------------------------------------------
# Identifiant du modèle de rerank configuré dans RAGFlow (UI ou API).
# Injecté automatiquement dans POST .../completions et dans POST /api/vox/retrieval.
#
# RAGFLOW_RERANK_ID=

# =============================================================================
# Variables utiles ailleurs (SSH, doc, scripts) — non requises par le build web
# =============================================================================
# Tu peux les garder dans .env.local pour toi ; le frontend Vite ne les injecte pas.
#
# RAGFLOW_BASE_URL=https://ragflow.example.com
# RAGFLOW_ADMIN_EMAIL=
# RAGFLOW_ADMIN_PASSWORD=
# VPS_SSH_USER=
# VPS_HOSTNAME=
